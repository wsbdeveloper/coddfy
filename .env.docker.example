# Copie para .env.docker se quiser usar env_file no compose (opcional).
# Dentro do Docker o host do banco é "db", não "localhost".

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=6543

DATABASE_URL=postgresql://ccm_user:ccm_password@db:5432/ccm_db

JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
